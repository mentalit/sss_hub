<%# app/views/pdf_imports/results.html.erb %>

<h1>PDF Import Results</h1>
<h2>Store: <%= @store.Storename %></h2>

<% if @date %>
  <p><strong>Report Date:</strong> <%= @date %></p>
<% end %>

<div style="display: flex; gap: 3rem; margin-top: 1.5rem;">

  <div>
    <h3>PA Counts</h3>
    <% if @pa_counts.any? %>
      <table border="1" cellpadding="6" cellspacing="0">
        <thead>
          <tr>
            <th>PA</th>
            <th>Count</th>
          </tr>
        </thead>
        <tbody>
          <% @pa_counts.each do |pa, count| %>
            <tr>
              <td><%= pa %></td>
              <td><%= count %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p>No PA data found.</p>
    <% end %>
  </div>

  <div>
    <h3>User ID Counts</h3>
    <% if @user_counts.any? %>
      <table border="1" cellpadding="6" cellspacing="0">
        <thead>
          <tr>
            <th>User ID</th>
            <th>Count</th>
          </tr>
        </thead>
        <tbody>
          <% @user_counts.each do |user_id, count| %>
            <tr>
              <td><%= user_id %></td>
              <td><%= count %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p>No User ID data found.</p>
    <% end %>
  </div>

</div>

<br>
<%= link_to "Import Another PDF", new_store_pdf_import_path(@store) %>
|
<%= link_to "Back to Store", @store %>
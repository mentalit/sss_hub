<p style="color: green"><%= notice %></p>
<div class="row">
  <div class="card col-2">
  <strong><%= @counter.user_id %></strong>
  Certified on <%= @counter.counter_cert_training %>
  </div>

 
   

 
   <div class="col-7">
    <div class="card col-2">
    <%= form_with url: counter_path(@counter), method: :get do |f| %>
      <%= f.date_field :date, value: @date %>
      <%= f.submit "Go" %>
    <% end %>
    </div>
   <%= render "counters/nav" %>
  </div>
</div>



<div class="row">
 
</div>

<%= render "comparisons/error_chart", chart_data: @chart_data, period_label: @period_label, user_charts: @user_charts, loss_total: @loss_total %>

<div>
  <%= link_to "Edit", edit_counter_path(@counter) %> |
  <%= link_to "Back to counters", store_counters_path(@store) %>
  <%= button_to "Destroy", @counter, method: :delete %>
</div> 
<h1>Weekly Comparison <%= @store.Storename %> </h2>

<div class="row">

  <div class="card col-2">
    <%= form_with url: day_store_comparisons_path(@store), method: :get do |f| %>
      <%= f.date_field :date, value: @date %>
      <%= f.submit "Go" %>
    <% end %>
  </div>

    <div class="card col-1">

      <%= link_to "Day", counter_day_store_comparisons_path(@store) %>
    </div>

  <div class="card col-1">
    <%= link_to "Week", counter_week_store_comparisons_path(@store) %>
  </div>


  <div class="card col-1">
    <%= link_to "Month", counter_month_store_comparisons_path(@store) %>
  </div>

  <div class="card col-1">
    <%= link_to "Year", counter_year_store_comparisons_path(@store) %>
  </div>

  <div class="card col-1">
    <%= link_to "Life", counter_life_store_comparisons_path(@store) %>
  </div>

</div>
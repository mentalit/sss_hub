<%# app/views/comparisons/year.html.erb %>

<h1>Yearly Comparison</h1>
<h2>Store: <%= @store.Storename %></h2>

<%= form_with url: year_store_comparisons_path(@store), method: :get do |f| %>
  <%= f.number_field :year, value: Date.today.year, min: 2020, max: Date.today.year %>
  <%= f.submit "Go" %>
<% end %>

<%= render "error_chart", chart_data: @chart_data, period_label: @period_label %>

<br>
<%= link_to "Back to Store", @store %>